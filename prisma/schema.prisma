generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

model Expense {
  id        String    @id @default(uuid())
  amount    Float
  category  String
  note      String?
  date      DateTime
  createdAt DateTime  @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}